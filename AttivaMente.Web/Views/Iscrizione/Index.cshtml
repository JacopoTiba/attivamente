@using AttivaMente.Web.ViewModels
@model IscrizioniIndexViewModel

<h2 class="mb-2">Iscrizioni - @Model.SelectedYear</h2>
<a asp-action="Statistiche" class="btn btn-secondary mb-3">Statistiche</a>
<a asp-action="CreateXlsx"
   asp-route-anno="@Model.SelectedYear"
   class="btn btn-success mb-3">Scarica XLSX anno selezionato</a>

<a asp-action="CreateXlsx"
   class="btn btn-success mb-3">Scarica XLSX tutti gli anni</a>
<form method="get" asp-action="Index" class="mb-3">
    <div class="d-flex justify-content-between align-items-end gap-3 flex-wrap">
        <div class="d-flex align-items-end gap-3 flex-wrap">
            <div>
                <label class="form-label mb-1">Anno:</label>
                <select name="anno" class="form-select w-auto py-2" onchange="this.form.submit()">
                    @foreach (var year in Model.Years)
                    {
                        <option value="@year" selected="@(year == Model.SelectedYear)">@year</option>
                    }
                </select>
            </div>

            <div>
                <label class="form-label mb-1 d-block">Visualizzazione</label>
                <div class="d-flex align-items-center gap-3 border rounded px-3 py-2 bg-light">
                    <div class="form-check mb-0">
                        <input class="form-check-input" type="radio" id="chkIsSoloIscritti" name="isSoloIscritti" value="true"
                               checked="@(Model.IsSoloIscritti)" onchange="this.form.submit()" />
                        <label class="form-check-label" for="chkIsSoloIscritti">Solo Iscritti</label>
                    </div>
                    <div class="form-check mb-0">
                        <input class="form-check-input" type="radio" id="chkIsTutti" name="isSoloIscritti" value="false"
                               checked="@(!Model.IsSoloIscritti)" onchange="this.form.submit()" />
                        <label class="form-check-label" for="chkIsTutti">Tutti</label>
                    </div>
                </div>
            </div>
        </div>

        <div class="d-flex align-items-end gap-2 flex-wrap">
            <div>
                <label for="ricerca" class="form-label mb-1">Cerca</label>
                <input class="form-control" type="text" id="ricerca" name="ricerca" value="@Model.Ricerca"
                       placeholder="Cognome e/o nome" style="min-width: 240px;" />
            </div>
            <div class="d-flex gap-2">
                <button class="btn btn-primary" type="submit">Cerca</button>
                <a class="btn btn-outline-secondary" asp-action="Index"
                   asp-route-anno="@Model.SelectedYear"
                   asp-route-isSoloIscritti="@Model.IsSoloIscritti">
                    Pulisci
                </a>
            </div>
        </div>
    </div>
</form>

<table class="table table-striped table-bordered align-middle">
    <thead class="table-light">
        <tr>
            <th>Cognome</th>
            <th>Nome</th>
            <th>Email</th>
            <th>Tipo</th>
            <th>Data Iscrizione</th>
            <th style="width: 140px;">AZIONI</th>
            <th>Storico</th>
        </tr>
    </thead>

    <tbody>
        @if (Model.Rows.Count == 0)
        {
            <tr>
                <td colspan="6" class="text-center text-muted">Nessun nominativo trovato.</td>
            </tr>
        }
        else
        {
            @foreach (var row in Model.Rows)
            {
                <tr>
                    <td>@row.Cognome</td>
                    <td>@row.Nome</td>
                    <td>@row.Email</td>
                    <td>
                        @if(row.Tipo != null)
                        {
                        <select class="iscrizione-field"
                                data-utenteid="@row.UtenteId"
                                data-anno="@Model.SelectedYear">
                                <option value="Nuova" selected="@(row.Tipo == "Nuova")">Nuova</option>
                                <option value="Rinnovo" selected="@(row.Tipo == "Rinnovo")">Rinnovo</option>
                        </select>
                        }
                        
                    </td>
                    <td>
                        @if(row.DataIscrizione != null)
                        {
                               <input type="date"
                               class="iscrizione-field"
                               data-utenteid="@row.UtenteId"
                               data-anno="@Model.SelectedYear"
                               value="@row.DataIscrizione?.ToString("yyyy-MM-dd")" />
                        }
                        
                        </td>
                    <td>
                        @if (row.Azione == "Cancella")
                        {
                            // Richiama l'azione Delete del Controller
                            <form method="post" asp-action="Delete" class="mb-0">
                                <input type="hidden" name="utenteId" value="@row.UtenteId" />
                                <input type="hidden" name="anno" value="@Model.SelectedYear" />
                                <input type="hidden" name="isSoloIscritti" value="@Model.IsSoloIscritti" />
                                <input type="hidden" name="ricerca" value="@Model.Ricerca" />
                                <button type="submit" class="btn btn-sm btn-outline-danger w-100">Cancella</button>
                            </form>
                        }
                        else if (row.Azione == "Rinnova")
                        {
                            // Richiama l'azione Renew del Controller
                            <form method="post" asp-action="Renew">
                                <input type="hidden" name="utenteId" value="@row.UtenteId" />
                                <input type="hidden" name="anno" value="@Model.SelectedYear" />
                                <input type="hidden" name="isSoloIscritti" value="@Model.IsSoloIscritti" />
                                <input type="hidden" name="ricerca" value="@Model.Ricerca" />
                                <button type="submit" class="btn btn-sm btn-outline-primary w-100">Rinnova</button>
                            </form>
                        }
                        else
                        {
                            // Richiama l'azione Subscribe del Controller
                            <form method="post" asp-action="Subscribe">
                                <input type="hidden" name="utenteId" value="@row.UtenteId" />
                                <input type="hidden" name="anno" value="@Model.SelectedYear" />
                                <input type="hidden" name="isSoloIscritti" value="@Model.IsSoloIscritti" />
                                <input type="hidden" name="ricerca" value="@Model.Ricerca" />
                                <button type="submit" class="btn btn-sm btn-outline-success w-100">Iscrivi</button>
                            </form>
                        }
                    </td>
                    <td>
                        <a asp-action="Storico" asp-controller="Iscrizione" asp-route-utenteId="@row.UtenteId" class="btn btn-info btn-sm">Storico</a>

                    </td>
                </tr>
            }
        }
    </tbody>
</table>

<script>
    document.querySelectorAll('.iscrizione-field').forEach(function(elemento) {
        elemento.addEventListener('change', function() {
            const utenteId = this.dataset.utenteid;
            const anno = this.dataset.anno;
            const tipo = document.querySelector('select[data-utenteid="' + utenteId + '"]').value;
            const dataIscrizione = document.querySelector('input[data-utenteid="' + utenteId + '"]').value;


            fetch('/Iscrizione/Update', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                utenteId: utenteId,
                anno: anno,
                tipo: tipo,
                dataIscrizione: dataIscrizione
            })
        }).then(function(response) {
            if (!response.ok) {
                alert('Errore nel salvataggio');
            }
        });
        
        });
    });
</script>
