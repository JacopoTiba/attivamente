@using AttivaMente.Core.Models
@using AttivaMente.Web.ViewModels
@model List<StatisticaAnnoViewModel>

<h2 class="mb-4">Statistiche iscrizioni per anno</h2>

<table class="table table-striped table-bordered">
    <thead class="table-light">
        <tr>
            <th>Anno</th>
            <th>Totale iscritti</th>
            <th>Nuove</th>
            <th>Rinnovi</th>
        </tr>
    </thead>
    <tbody>
        @if (Model.Count == 0)
        {
            <tr>
                <td colspan="4" class="text-center text-muted">Nessuna statistica disponibile.</td>
            </tr>
        }
        else
        {
            @foreach (var stat in Model)
            {
                <tr>
                    <td>@stat.Anno</td>
                    <td>@stat.Totale</td>
                    <td>@stat.Nuove</td>
                    <td>@stat.Rinnovi</td>
                </tr>
            }
        }
    </tbody>
</table>

<a asp-action="Index" class="btn btn-secondary">Torna alle iscrizioni</a>