@model List<AttivaMente.Core.Models.Iscrizione>

<h2>Storico iscrizioni - @ViewBag.Utente</h2>

<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>Anno</th>
            <th>Tipo</th>
            <th>Data Iscrizione</th>
        </tr>
    </thead>
    <tbody>
        @if (Model.Count == 0)
        {
            <tr>
                <td colspan="6" class="text-center text-muted">Nessuna iscrizione registrata per questo utente</td>
            </tr>
        }
        else
        {
            @foreach (var iscrizione in Model)
            {
                <tr>
                    <td>@iscrizione.Anno</td>
                    <td>@iscrizione.Tipo</td>
                    <td>@iscrizione.DataIscrizione.ToString("dd/MM/yyyy")</td>
                </tr>
            }

        }
    </tbody>
</table>

<a asp-action="Index" class="btn btn-secondary">Torna indietro</a>
